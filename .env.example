# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# REDIS_TTL_SECONDS: Configurable Redis cache TTL in seconds. Default is 86400 (24 hours).
REDIS_TTL_SECONDS="86400"

# REDIS_URL: Connection URL for production Redis instance (including SSL/TLS options)
REDIS_URL="redis://default:gQAAAAAAAQsHAAIgcDI1Y2E0NDczZmIzYmM0NGI1YWRjNDk2ZmEyZDJkMmY0Yg@champion-blowfish-68359.upstash.io:6379"

# YOUTUBE_API_KEY: Optional/Required for YouTube Playlist Import feature if not fallback-supported.
YOUTUBE_API_KEY="YOUR_YOUTUBE_API_KEY"

